{
  "name": "local-forge",
  "displayName": "LocalForge",
  "description": "Local-first AI development platform â€” VS Code extension + CLI + Web UI with multi-agent workflow (Plannerâ†’Writerâ†’Reviewerâ†’Tester)",
  "version": "0.1.0",
  "publisher": "nrupala",
  "author": {
    "name": "Nrupal Akolkar",
    "email": "nrupalakolkar@gmail.com"
  },
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nrupala/LocalForge"
  },
  "homepage": "https://nrupala.github.io/LocalForge",
  "bugs": {
    "url": "https://github.com/nrupala/LocalForge/issues"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Chat",
    "Other"
  ],
  "keywords": [
    "llm",
    "ai",
    "code generation",
    "multi-agent",
    "workflow",
    "local",
    "llama.cpp",
    "gguf",
    "copilot alternative",
    "claude code alternative"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onCommand:localForge.analyzeContext",
    "onCommand:localForge.focusTasks"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "localForge.analyzeContext",
        "title": "LocalForge: Extract Context Map"
      },
      {
        "command": "localForge.focusTasks",
        "title": "LocalForge: Focus Tasks Panel"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "localforge-sidebar",
          "title": "LocalForge",
          "icon": "$(terminal)"
        }
      ]
    },
    "views": {
      "localforge-sidebar": [
        {
          "type": "webview",
          "id": "localforge.taskManagerView",
          "name": "LocalForge Console"
        }
      ]
    }
  },
  "bin": {
    "localforge": "./out/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node out/cli.js",
    "server": "node out/server.js",
    "run": "node out/cli.js run",
    "workflow": "node out/cli.js workflow"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/vscode": "^1.120.0",
    "typescript": "^6.0.3"
  }
}
