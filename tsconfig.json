{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "target": "ES2022",
    "outDir": "./out",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "sourceMap": true,
    "strict": true,
    "rootDir": "./src",
    "skipLibCheck": true,
    "types": [
      "node"
    ]
  },
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}